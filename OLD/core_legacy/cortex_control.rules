[CONTROL_MODEL]
LEVEL = DEVELOPMENT
SANDBOX = TRUE
ALLOW_INTERNAL_EVOLUTION = LIMITED

[HARD_GUARDS]
NO_AUTONOMOUS_REAL_WORLD_ACTIONS = TRUE
NO_DIRECT_SYSTEM_COMMANDS = TRUE
NO_DIRECT_NETWORK_SCANS = TRUE
NO_PRIVILEGED_DATA_ACCESS = TRUE

[EVOLUTION_RULES]
ALLOW_CODE_SUGGESTIONS = TRUE
ALLOW_SELF_IMPROVEMENT_LOGIC = TRUE
REQUIRE_HUMAN_REVIEW_FOR_PATCHES = TRUE
ALLOW_NEW_DOMAINS = TRUE

			if (href != null && href.includes("/eurostat/documents/")) {
				//ec.europa.eu/eurostat/documents/3217494/13389103/KS-HA-21-001-EN-N.pdf/1358b0d3-a9fe-2869-53a0-37b59b413ddd?t=1631630029904

async function getApiData(serviceName, serviceUrl) {
  const url = 'https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data/' + serviceUrl
  // console.debug(serviceName + ' URL: ' + url)
  const response = await fetch(url)
  return await response.json()
}

document.addEventListener('DOMContentLoaded', function () {

  const carousel = fragmentElement.querySelectorAll('.glide__slide')
  const orderArr = configuration.orderBoxes.split(',')
  // if order array is smaller, make them equal in length
  if (orderArr.length < carousel.length) {
    for (let i = orderArr.length; i < carousel.length; i++) {
      orderArr.push((i+1).toString())
    }
  }
  if (configuration.autoOrder) {
    for (let i = orderArr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [orderArr[i], orderArr[j]] = [orderArr[j], orderArr[i]]
    }
  }
  // apply order to carousel
  for (let i = 0; i < carousel.length; i++) {
    carousel[i].style.order = orderArr[i].toString()
  }
    
  const euki = document.querySelector('.euki')
  let errorCount = 0
  
  // EUKI: Government deficit
  if (!configuration.hideEukiGovernmentDeficit) {
    getApiData('Government Deficit', 'gov_10dd_edpt1?format=JSON&freq=A&unit=PC_GDP&geo=EU27_2020&na_item=B9&sector=S13')
    .then(data => {
      // console.debug(data)
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#government-deficit-period').innerHTML = timePeriod
      euki.querySelector('#government-deficit-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#government-deficit') })
  }

  // EUKI: Government debt
  if (!configuration.hideEukiGovernmentDebt) {
    getApiData('Government Debt', 'gov_10dd_edpt1?format=JSON&freq=A&unit=PC_GDP&geo=EU27_2020&na_item=GD&sector=S13')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#government-debt-period').innerHTML = timePeriod
      euki.querySelector('#government-debt-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#government-debt') })
  }

  // EUKI: Inflation Rate
  if (!configuration.hideEukiInflationRate) {
    getApiData('Inflation Rate', 'prc_hicp_minr?geo=EU&unit=RCH_A&coicop18=TOTAL')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#inflation-rate-period').innerHTML = timePeriod
      euki.querySelector('#inflation-rate-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#inflation-rate') })
  }

  // EUKI: GDP Growth
  if (!configuration.hideEukiGDPGrowth) {
    getApiData('GDP Growth', 'namq_10_gdp?na_item=B1GQ&geo=EU27_2020&unit=CLV_PCH_PRE&s_adj=SCA')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#gdp-growth-period').innerHTML = timePeriod
      euki.querySelector('#gdp-growth-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#gdp-growth') })
  }

  // EUKI: Unemployment rate
  if (!configuration.hideEukiUnemploymentRate) {
    getApiData('Unemployment rate', 'une_rt_m?sex=T&geo=EU27_2020&unit=PC_ACT&s_adj=SA&age=TOTAL')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#unemployment-period').innerHTML = timePeriod
      euki.querySelector('#unemployment-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#unemployment') })
  }

  // EUKI: Housing prices
  if (!configuration.hideEukiHousingPrices) {
    getApiData('Housing prices', 'prc_hpi_q?purchase=TOTAL&geo=EU27_2020&unit=RCH_A')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#housing-prices-period').innerHTML = timePeriod
      euki.querySelector('#housing-prices-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#housing-prices') })
  }

  // EUKI: Population
  if (!configuration.hideEukiPopulation) {
    getApiData('Population', 'demo_gind?indic_de=JAN&geo=EU27_2020')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#population-period').innerHTML = timePeriod
      euki.querySelector('#population-value').innerHTML = latestKeyValue[1].toString().match(/.{1,3}/g).join(' ')
    })
    .catch(error => { handleError(error, '#population') })
  }

  // EUKI: Energy inflation rate
  if (!configuration.hideEukiEnergyInflationRate) {
    getApiData('Energy inflation rate', 'prc_hicp_manr?geo=EU&unit=RCH_A&coicop=NRG')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#energy-inflation-period').innerHTML = timePeriod
      euki.querySelector('#energy-inflation-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#energy-inflation') })
  }

  // EUKI: Food inflation rate
  if (!configuration.hideEukiFoodInflationRate) {
    getApiData('Food inflation rate', 'prc_hicp_manr?geo=EU&unit=RCH_A&coicop=CP011')
    .then(data => {
      const latestKeyValue = Object.entries(data.value).pop()
      const timeCategoryIndex = data.dimension.time.category.index
      const timePeriod = Object.keys(timeCategoryIndex).find(key => timeCategoryIndex[key] == latestKeyValue[0])
      euki.querySelector('#food-inflation-period').innerHTML = timePeriod
      euki.querySelector('#food-inflation-value').innerHTML = latestKeyValue[1].toFixed(1)
    })
    .catch(error => { handleError(error, '#food-inflation') })
  }
    
  function handleError(error, cssSelector) {
    // console.debug(cssSelector, error)
    euki.querySelector(cssSelector).style.display = "none"
    errorCount++
    // hide euki section if more than 3 produce an error
    if (errorCount > 3 && euki.style.display != 'none') {
      euki.style.display = 'none'
    }
  }
});}());</script>

											


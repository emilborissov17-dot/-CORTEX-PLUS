ey"]],"^P","Surveys"],["^ ","^1R","Download publicly available World Bank datasets from the","img","/media/platform/datasets.svg","^15","https://datacatalog.worldbank.org/","^1S",6812,"^1T","Data Catalog","^1U",[["^ ","^15","https://www.worldbank.org/en/programs/debt-statistics","^P","International debt statistics"],["^ ","^15","https://www.worldbank.org/en/programs/statistical-performance-indicators","^P","Statistical performance indicators"],["^ ","^15","https://datacatalog.worldbank.org/search/dataset/0037798","^P","Global economic monitor"]],"^P","Datasets"]],"tabMenu",[["^ ","^15","/","^P","HOME"],["^ ","^15","https://data360.worldbank.org/en/economies","^P","ECONOMIES"],["^ ","^P","THEMES"],["^ ","^15","https://data360.worldbank.org/en/search","^P","DATA & RESOURCES"],["^ ","^15","https://data360.worldbank.org/en/about","^P","ABOUT"]]],"metadata_fields",["^ ","country",["^ ","IncomeGroup",["^ ","weight",-1],"Lendingcategory",["^ ","^1Y",-1],"LongName",["^ ","^1Y",-2],"PPPsurveyyear",false,"Region",["^ ","^1Y",-1]],"indicator",["^ ","Aggregationmethod",["^ ","^1Y",-1],"Developmentrelevance",["^ ","^1Y",-1]]],"banner",["^ ","^4",false],"en_TopicPortalData",["^ ","3",["^ ","^K","Economy & Growth","portals",[["^ ","descriptionHtml","The <a href='http://datatopics.worldbank.org/consumption/'>Global Consumption Database</a> is a one-stop source of data on household consumption patterns in developing countries. It is designed to serve a wide range of users - from researchers seeking data for analytical studies to businesses seeking a better understanding of the markets into which they are expanding or those they are already serving.","href","http://datatopics.worldbank.org/consumption/","img","/media/portal-images/Portal-Global-Consumption-Database.jpg","^K","Household Consumption Data and Statistics"]]],"4",["^ ","^K","Education","^25",[["^ ","^26","The <a href='http://datatopics.worldbank.org/education'>World Bank EdStats</a> (Education Statistics) portal is your comprehensive data and analysis source for key topics in education. EdStats tools, resources and queries help users visualize and analyze education data.","^27","http://datatopics.worldbank.org/education","img","/media/portal-images/Portal-EdStats.png","^K","Education Statistics: EdStats"],["^ ","^26","<a href='http://datatopics.worldbank.org/sdi'> Service Delivery Indicators </a> is a Africa wide initiative that collects actionable data on service delivery in schools and health facilities to assess quality and performance, track progress, and empower citizens to hold governments accountable for public spending.","^27","http://datatopics.worldbank.org/sdi","img","/media/portal-images/Portal-Service-Delivery-Indicators.jpg","^K","Service Delivery Indicators"]]],"5",["^ ","^K","Energy & Mining","^25",[["^ ","^26","The <a href='https://energydata.info'>Energy &amp; Extractives Open Data Platform </a> is provided by the World Bank Group and is comprised of open datasets relating to the work of the Energy &amp; Extractives Global Practice, including statistical, measurement and survey data from ongoing projects.","^27","https://energydata.info","img","/media/portal-images/Portal-EE-OpenData.png","^K","Energy & Extractives Open Data Platform"]]],"7",["^ ","^K","Financial Sector","^25",[["^ ","^26","The <a href='http://datatopics.worldbank.org/g20fidata'>G20 Financial Inclusion Indicators</a> were developed by the Global Partnership for Financial Inclusion (GPFI) and were endorsed by G20 Leaders at their St. Petersburg Summit in September 2013.","^27","http://datatopics.worldbank.org/g20fidata","img","/media/portal-images/Portal-G20-Financial-Inclusion-Indicators.jpg","^K","Financial Inclusion"]]],"8",["^ ","^K","Health","^25",[["^ ","^26","<a href='http://datatopics.worldbank.org/hnp'>HealthStats</a> is the World Bank\"s comprehensive database of Health, Nutrition and Population (HNP) statistics.","^27","http://datatopics.worldbank.org/hnp","img","/media/portal-images/Portal-HNP.png","^K","HealthStats"],["^ ","^26","<a href='http://datatopics.worldbank.org/sdi'>Service Delivery Indicators</a> is a Africa wide initiative that collects actionable data on service delivery in schools and health facilities to assess quality and performance, track progress, and empower citizens to hold governments accountable for public spending.","^27","http://datatopics.worldbank.org/sdi","img","/media/portal-images/Portal-Service-Delivery-Indicators.jpg","^K","Service Delivery Indicators"]]],"10",["^ ","^K","Social Protection & Labor","^25",[["^ ","^26","<a href='http://datatopics.worldbank.org/aspire'>ASPIRE</a> is an ongoing project to compile comprehensive and harmonized data on Social Protection and Labor (SPL) programs and systems.","^27","https://www.worldbank.org/en/data/datatopics/aspire","img","/media/portal-images/Portal-ASPIRE.jpg","^K","ASPIRE: The Atlas of Social Protection"],["^ ","^26","<p>Access regional and country dashboards displaying tables and graphs with the latest data and trends on Jobs.</p>","^27","https://datatopics.worldbank.org/jobsdiagnostics/","img","/media/portal-images/Portal-Jobs.jpg","^K","Jobs Diagnostics"]]],"11",["^ ","^K","Poverty","^25",[["^ ","^26","The <a href='https://pip.worldbank.org/'>Poverty and Inequality Platform</a> website allows you to explore data and indicators based on different poverty lines.","^27","https://pip.worldbank.org/","img","/media/portal-images/Portal-Poverty-Equity-Data.jpg","^K","Poverty and Inequality Platform"]]],"12",["^ ","^K","Private Sector","^25",[["^ ","^26","The <a href='http://www.doingbusiness.org'>Doing Business project</a> provides objective measures of business regulations for local firms in 189 economies and selected cities at the subnational level.","^27","http://www.doingbusiness.org/","img","/media/portal-images/Portal-Doing-Business.jpg","^K","Doing Business"],["^ ","^26","<a href='http://www.enterprisesurveys.org/'>Enterprise Surveys</a> provide the world\"s most comprehensive company-level data in emerging markets and developing economies. Business data are available on 130,000 firms in 135 countries.","^27","http://www.enterprisesurveys.org/","img","/media/portal-images/Portal-Enterprise-Surveys.jpg","^K","Enterprise Surveys"],["^ ","^26","The <a href='http://datatopics.worldbank.org/consumption/'>Global Consumption Database</a> is a one-stop source of data on household consumption patterns in developing countries. It is designed to serve a wide range of users - from researchers seeking data for analytical studies to businesses seeking a better understanding of the markets into which they are expanding or those they are already serving.","^27","http://datatopics.worldbank.org/consumption/","img","/media/portal-images/Portal-Global-Consumption-Database.jpg","^K","Household Consumption Data and Statistics"]]],"13",["^ ","^K","Public Sector","^25",[["^ ","^26","The World Bank’s <a href='http://datatopics.worldbank.org/statisticalcapacity'>Statistical Capacity Indicator</a> is a composite score assessing the capacity of a country\"s statistical system. It is based on a diagnostic framework consisting of three assessment areas: methodology; data sources; and periodicity and timeliness.","^27","http://datatopics.worldbank.org/statisticalcapacity","img","/media/portal-images/Portal-Data-on-Statistical-Capacity.jpg","^K","Data on Statistical Capacity"],["^ ","^26","The <a href='http://datatopics.worldbank.org/cpia'>Country Policy &amp; Institution Assessment</a> (CPIA) is a diagnostic tool that is intended to capture the quality of a country\"s policies and institutional arrangements.","^27","http://datatopics.worldbank.org/cpia","img","/media/portal-images/Portal-CPIA.jpg","^K","Country Policy & Institutional Assessments"]]],"17",["^ ","^K","Gender","^25",[["^ ","^26","The <a href='http://datatopics.worldbank.org/gender'>Gender Data Portal</a> is a one-stop source of information on gender at the country level—a compilation of data on key gender topics from national statistics agencies, United Nations databases, and World Bank-conducted or funded surveys.","^27","http://datatopics.worldbank.org/gender","img","/media/portal-images/Portal-GenderStats.png","^K","Gender Equality Data & Statistics"]]],"19",["^ ","^K","Climate Change","^25",[["^ ","^26","The <a href='https:climateknowledgeportal.worldbank.org'>Climate Change Knowledge Portal</a> (CCKP) provides climate data and climate-risk information for users to understand and communicate future climate change scenarios.","^27","http://climateknowledgeportal.worldbank.org","img","/media/portal-images/portal-climate-change-2021.jpeg","^K","Climate Change Knowledge Portal"],["^ ","^26","The <a href='http://carbonpricingdashboard.worldbank.org'>Carbon Pricing Dashboard</a> provides up-to-date information on existing and emerging carbon pricing initiatives around the world.","^27","http://carbonpricingdashboard.worldbank.org","img","/media/portal-images/carbonpricingdashboard.png","^K","Carbon Pricing Dashboard"]]],"20",["^ ","^K","External Debt","^25",[["^ ","^26","The <a href='http://datatopics.worldbank.org/debt'>Debt Data portal</a> serves as a central hub for information and access to debt statistics.","^27","http://datatopics.worldbank.org/debt","img","/media/portal-images/Portal-Global-Debt-Data.jpg","^K","Debt Data"]]],"21",["^ ","^K","Trade","^25",[["^ ","^26","The <a href='http://wits.worldbank.org'>World Integrated Trade Solution (WITS)</a> tool accesses and retrieves information on trade and tariffs which is compiled by several international organizations, including the World Bank. WITS allows you to quickly obtain summary trade and tariff related information without having to execute queries.","^27","http://wits.worldbank.org/","img","/media/portal-images/Portal-WITS.jpg","^K","WITS: World Integrated Trade Solution"],["^ ","^26","<a href='http://tcdata360.worldbank.org'>TCdata360</a> aggregates 2000+ trade and competitiveness related indicators from 25+ sources inside and outside WBG and presents them in interactive, visual fashion. Users can compare countries over time, download data, create data visualization, read data stories, see data on maps, print reports, copy charts, connect through an API, and more.","^27","http://tcdata360.worldbank.org","img","/media/portal-images/Portal-TCData360.png","^K","TCdata360"]]]],"front_page/en_front_page_config",["^ ","DATA_360",[["^ ","countries",["1W"],"^I","Investing in people through education, health, social protection, and gender equality","endYear",2023,"img","/media/data360/people-en.jpg","^22","SE.PRM.CMPT.FE.ZS","profileLinkProd","https://data360.worldbank.org/en/theme/people","profileLinkStag","https://wwwstg.worldbank.org/en/data360/people","startYear",1972,"^P","People profile","type","chart"],["^ ","^29",["1W"],"^I","Promoting economic policies for growth","^2:",2023,"img","/media/data360/prosperity-en.jpg","^22","SI.POV.DDAY","^2;","https://data360.worldbank.org/en/theme/prosperity","^2<","https://wwwstg.worldbank.org/en/data360/prosperity","^2=",1981,"^P","Prosperity profile","^2>","chart"],["^ ","^29",["1W"],"^I","Sustaining the planet’s natural resources for inclusive growth","^2:",2023,"img","/media/data360/planet-en.jpg","^22","EN.GHG.CO2.MT.CE.AR5","^2;","https://data360.worldbank.org/en/theme/planet","^2<","https://wwwstg.worldbank.org/en/data360/planet","^2=",1960,"^P","Planet profile","^2>","chart"],["^ ","^29",["1W"],"^I","Promoting clean energy access, sustainable transport and livable cities","^2:",2023,"img","/media/data360/infrastructure-en.jpg","^22","EG.ELC.ACCS.ZS","^2;","https://data360.worldbank.org/en/theme/infrastructure","^2<","https://wwwstg.worldbank.org/en/data360/infrastructure","^2=",1990,"^P","Infrastructure profile","^2>","chart"],["^ ","^29",["1W"],"^I","Eliminating the digital divide","^2:",2023,"img","/media/data360/digital-en.jpg","^22","IT.NET.USER.ZS","^2;","https://data360.worldbank.org/en/theme/digital","^2<"
<script>
	document.addEventListener('DOMContentLoaded', () => {
		const intersectionObserverOptions = { rootMargin: "0px 0px -100px 0px", threshold: 0 }
		
		const keyNumbers = document.querySelectorAll('.key-number');
		
		if (keyNumbers.length > 0) {
			let timeoutValue = 0;
			
			function numberWithCommas(x) {
				return x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
			}

			function animateNumber(el) {
				const endValue = el.dataset.endValue,
							elSuffix = el.dataset.suffix || "",
							elPrefix = el.dataset.prefix || "",
							elComma = !!el.dataset.comma;
				
				const isDecimalNumber = endValue.indexOf('.') !== -1;
				
				console.log({endValue, isDecimalNumber})
				anime({
					targets: el,
					textContent: endValue.trim(),
					round: isDecimalNumber ? 10 : 1,
					easing: 'easeInOutQuad',
					duration: 2500,
					update: function(a) {
						let value = a.animations[0].currentValue.trim();
						if (isDecimalNumber) {
							value += a.animations[0].currentValue.indexOf('.') === -1 ? ".0" : "";
						}
						
						if (elComma) {
							value = numberWithCommas(value);
						}
						
						el.textContent = `${elPrefix}${value}${elSuffix}`;
					}
				});
			}

			const keyNumbersObserver = new IntersectionObserver((entries, sectionObserver) => {
				entries.forEach((entry, index) => {
					if (entry.isIntersecting) {
						if (typeof anime === "function") {
							timeoutValue += 100;
							setTimeout(() => {
								animateNumber(entry.target);
								timeoutValue = 0
							}, timeoutValue);
						}
						keyNumbersObserver.unobserve(entry.target);
					}
				})
			}, intersectionObserverOptions);

			keyNumbers.forEach(elem => {
				keyNumbersObserver.observe(elem)
			})
		}
		
		
		
	})
</script>



    function createCustomPagination() {
      var paginationContainer = document.querySelector(".vertical_pagination");
      var slides = document.querySelectorAll(".vertical_item");
      slides.forEach((slide, index) => {
        var bullet = document.createElement("div");
        bullet.classList.add("vertical_pagination_bullet");

        paginationContainer.appendChild(bullet);
      });

      const bullets = document.querySelectorAll(".vertical_pagination_bullet");
      bullets.forEach((bullet, index) => {
        bullet.addEventListener("click", () => {
          swiper.slideToLoop(index);
        });
      });

      const slideNumbers = document.querySelectorAll(".vertical_item_number");
      slideNumbers.forEach((eachSlideNumber, index) => {
        eachSlideNumber.innerHTML = `${index + 1} // ${slides.length}`;
      });
    }

    function updateCustomPagination(swiper) {
      var bullets = document.querySelectorAll(".vertical_pagination_bullet");
      bullets.forEach((bullet, index) => {
        bullet.classList.remove("vertical_pagination_bullet-active");
        if (index === swiper.realIndex) {
          bullet.classList.add("vertical_pagination_bullet-active");
        }
      });
    }
  });
</script></div></section><div class="spacing-negative-small"></div><section class="section_image medium"><div class="image_component"><img src="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667dcc50e6008315aec6b551_BG-tall-energy-storage-containers-mirror-14.png" loading="lazy" alt="" sizes="(max-width: 1512px) 100vw, 1512px" srcset="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667dcc50e6008315aec6b551_BG-tall-energy-storage-containers-mirror-14-p-500.png 500w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667dcc50e6008315aec6b551_BG-tall-energy-storage-containers-mirror-14-p-800.png 800w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667dcc50e6008315aec6b551_BG-tall-energy-storage-containers-mirror-14.png 1512w" class="image_image five"/></div></section><section class="section_articles"><div class="container-large padding-section-medium"><div class="articles_component"><h2>Energy storage is a leading technology for boosting grid reliability and lowering energy costs for families and businesses.</h2><div class="articles_content"><div class="articles_item"><div class="articles_item_preheading">Nevada</div><h3 class="articles_item_heading"><strong>Energy Storage Project to Reduce Costs 15-20%</strong></h3><div class="articles_item_text">In Nevada, a new battery storage facility built on the site of a former coal plant is expected to reduce customer bills by 15-20%, while enhancing grid reliability by storing excess solar energy during the day to use during peak hours.<br/></div><a href="https://www.ktnv.com/news/nv-energy-aims-to-reduce-customer-costs-save-energy-with-new-solar-battery-storage-facility" target="_blank" class="articles_item_button is-magnet w-inline-block"><div>Read the article</div><img src="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/6660e6d1f1fc4b03d8c94c5f_cloud%20file.svg" loading="lazy" alt="" class="button_icon"/></a></div><div class="articles_item"><div class="articles_item_preheading">California</div><h3 class="articles_item_heading"><strong>How New Battery Capacity Helped California Avoid Another Blackout</strong></h3><div class="articles_item_text">“The August 2020 heatwave resulted in a surge in demand to a peak of 46.8 GW, which resulted in blackouts. Even though the September 2022 heatwave caused a higher demand of 51.4 GW, new BES[S] provided 3.4 GW of peak generation to help prevent the blackouts.”<br/></div><a href="https://www.icf.com/insights/energy/battery-energy-storage-blackouts-california" target="_blank" class="articles_item_button is-magnet w-inline-block"><div>Read the article</div><img src="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/6660e6d1f1fc4b03d8c94c5f_cloud%20file.svg" loading="lazy" alt="" class="button_icon"/></a></div></div></div></div><div class="articles_embed w-embed"><style>

.articles_item_button .button_icon {
display: none;
}

.articles_item_button.with-icon .button_icon {
display: block;
}

</style></div></section><section data-wf--section-panel--variant="base" class="section_panel"><div class="container-large"><div class="panel_component"><div class="panel_row reverse"><div class="panel_content"><div class="panel_richtext w-richtext"><h3>Our partnerships</h3><p>Local fire departments and first responders work with storage developers on safety training, sharing information about how the technologies work, and developing joint response plans and safety strategies.</p><p>‍</p><p>State and local governments can support and promote safety by adopting NFPA 855, the gold standard for energy storage safety developed by fire service professionals and fire protection experts. Uniform adoption of NFPA 855 ensures best practices are utilized across the United States.</p></div><a href="/partnerships" class="button in-panel w-button">Meet our partners</a></div><div class="panel_video-wrap2"><div class="panel_video-wrap"><img src="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters.webp" loading="lazy" alt="" sizes="100vw" srcset="https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters-p-500.webp 500w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters-p-800.webp 800w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters-p-1080.webp 1080w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters-p-1600.webp 1600w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters-p-2000.webp 2000w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c025132b03c8337673efc_team-of-american-firefighters.webp 2074w" class="panel_image"/></div></div></div></div></div><div class="panel_logic w-embed w-script"><!--
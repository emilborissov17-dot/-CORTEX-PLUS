      // Function to initialize the Vimeo player
      function initializeVimeoPlayer() {
        const twoColumnSections = document.querySelectorAll(".section_two-column");

        if (twoColumnSections) {
          twoColumnSections.forEach((twoColumnSection) => {
            const twoColumnVideo = twoColumnSection.querySelector(".two-column_video_vid");

            if (twoColumnVideo) {
              const twoColumnVideoPlayer = new Vimeo.Player(twoColumnVideo);

              const twoColumnWrap = twoColumnVideo.closest(".two-column_video-wrap");
              const twoColumnImage = twoColumnWrap.querySelector(".two-column_video_image");
              const twoColumnOverlay = twoColumnWrap.querySelector(".two-column_video_overlay");
              const play = twoColumnWrap.querySelector(".two-column_video_play");
              const pause = twoColumnWrap.querySelector(".two-column_video_pause");
              const unpause = twoColumnWrap.querySelector(".two-column_video_unpause");
              const twoColumnToggle = twoColumnWrap.querySelector(".two-column_video_toggle");

              play.addEventListener("click", function () {
                twoColumnVideoPlayer.play();
                twoColumnVideoPlayer.setMuted(false);
                twoColumnImage.style.display = "none";
                twoColumnOverlay.style.display = "none";
                twoColumnToggle.style.display = "flex";
              });

              unpause.addEventListener("click", function () {
                twoColumnVideoPlayer.play();
                twoColumnVideoPlayer.setMuted(false);
                unpause.style.display = "none";
                pause.style.display = "flex";
              });

              pause.addEventListener("click", function () {
                twoColumnVideoPlayer.pause();
                unpause.style.display = "flex";
                pause.style.display = "none";
              });
            }
          });
        }
      }

      // Call the function to load the script
      loadVimeoScript();
      twoColumnLogicExecuted = true;
    }
  });

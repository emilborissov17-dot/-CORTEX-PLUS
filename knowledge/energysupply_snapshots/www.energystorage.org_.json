              unpause.style.display = "none";
              pause.style.display = "flex";
            });

            pause.addEventListener("click", function () {
              panelVideoPlayer.pause();
              unpause.style.display = "flex";
              pause.style.display = "none";
            });
          }
        });
      }
    }

    // Call the function to load the script
    loadVimeoScript();
    panelLogicExecuted = true;
  }
</script></div></section><section id="cta" class="section_cta"><div class="container-large padding-section-small"><div class="cta_component"><div class="cta_text-wrap"><div class="cta_text">Energy Storage is<br/></div><div class="cta_text-typed-wrap"><div class="cta_text-typed"></div></div></div></div></div><div class="cta_embed w-richtext"><div class="w-embed w-script"><script src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>


db977aafae5c7f_BG-tall-BESS-with-transmission-lines-14-p-800.png 800w, https://cdn.prod.website-files.com/665e6f7e8f49ea56f1d1fe37/667c7116f9db977aafae5c7f_BG-tall-BESS-with-transmission-lines-14.png 1512w" class="image_image"/></div></section><div class="section_hero1"><div class="container-large padding-section-small"><div class="hero1_component"><div class="hero1_content"><div class="hero1_heading-wrap"><div class="hero1_heading w-richtext"><h1>Energy storage is a critical part of U.S. infrastructure—</h1></div><div class="hero1_richtext w-richtext"><h1>keeping the grid reliable, lowering energy costs, minimizing power outages, increasing U.S. energy production, and strengthening national security.</h1></div></div><div class="hero1_articles"><div class="articles_item hero1 hide"><div class="articles_item_preheading"></div><h3 class="articles_item_heading">Keeping the grid reliable</h3><div class="articles_item_text">Energy storage efficiently and conveniently captures electricity so that it can be used whenever and wherever it’s most needed.</div></div><div class="articles_item hero1 hide"><h3 class="articles_item_heading">Lowering Energy Costs</h3><div class="articles_item_text">Energy storage reduces energy waste, improves grid efficiency, limits costly energy imports, prevents and minimizes power outages, and allows the grid to use more affordable clean energy resources—all of which reduce energy costs for consumers.</div></div><div class="articles_item hero1 hide"><h3 class="articles_item_heading">Minimizing Power Outages</h3><div class="articles_item_text">Energy storage prevents or reduces the risk of blackouts or brownouts by serving as critical backup power for homes, businesses, communities, and entire state and regional electric grids.</div></div><div class="articles_item hero1 hide"><h3 class="articles_item_heading">Increasing U.S. Energy Production</h3><div class="articles_item_text">Energy storage facilitates the expansion of U.S. energy production, supporting the addition of all types of new energy sources.</div></div><div class="articles_item hero1 hide"><h3 class="articles_item_heading">Strengthening National Security</h3><div class="articles_item_text">Energy storage strengthens our energy independence and national security by maximizing the use of affordable electricity produced in the United States, reducing the need for costly imported energy.</div></div></div></div><div data-line-height="height-100" class="hero1_line"></div></div></div><div class="hero1_embed w-embed w-script"><script>
  var Webflow = Webflow || [];
  Webflow.push(function () {
    // Webflow is done loading

    // Check if hero1Logic is already executed. var for hero1LogicExecuted defined in global embed
    if (!hero1LogicExecuted) {
      // Function to create a span around each text part
      function wrapTextWithSpan(parentElement, text) {
        const span = document.createElement("span");
        span.className = "hoverable-text";
        span.textContent = text;
        parentElement.appendChild(span);
      }

      const allHeros = document.querySelectorAll(".section_hero1");

      allHeros.forEach((eachHero) => {
        // Select the text content after "United States"
        const richTextElement = eachHero.querySelector(".hero1_richtext h1");
        const richTextContent = richTextElement.textContent;

        // Split the text into parts based on commas, including the comma with the text part
        const textParts = richTextContent.split(/, /);

        // Clear the original content
        richTextElement.innerHTML = "";

        // Create spans for each part of the text and append to the rich text element
        textParts.forEach((part, index) => {
          wrapTextWithSpan(richTextElement, part + (index < textParts.length - 1 ? "," : ""));
          if (index < textParts.length - 1) {
            // Add the space after the comma outside the span
            richTextElement.appendChild(document.createTextNode(" "));
          }
        });

        // Select all article items
        const articleItems = eachHero.querySelectorAll(".hero1_articles .articles_item");

        // Add hover event listeners
        eachHero.querySelectorAll(".hoverable-text").forEach((element, index) => {
          if (index < articleItems.length) {
            element.addEventListener("mouseenter", () => {
              articleItems[index].classList.remove("hide");
              // for mobile
              if (index != 0) {
                document.querySelector(".hoverable-text").classList.remove("active");
                articleItems[0].classList.add("hide");
              }
            });
            element.addEventListener("mouseleave", () => {
              articleItems[index].classList.add("hide");
            });
          }
        });

        hero1LogicExecuted = true;

        // making it touch the first one by default on tablet and mobile
        if (window.innerWidth < 990) {
          const hoverableElement = document.querySelector(".hoverable-text");

          if (hoverableElement) {
            hoverableElement.classList.add("active");
            articleItems[0].classList.remove("hide");
          }
        }
      });
    }
  });
</script></div></div><section class="section_two-column"><div class="two-column_logic w-embed w-script"><script>

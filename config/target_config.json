    },
    "TECHNOLOGY_AI_REVIEW": {
      "primary_metric": null,
      "target_value": null,
      "direction": "higher_better",
      "weight": 6,
      "unit": "qualitative score",
      "rationale": "Beneficial AI adoption; no numeric global threshold exists"
    },
    "TECHNOLOGY_INFRA_REVIEW": {
      "primary_metric": null,
      "target_value": null,
      "direction": "higher_better",
      "weight": 5,
      "unit": "qualitative score",
      "rationale": "Digital infrastructure access — approximate only"
    }
  },

  "COSMOS": {
    "COSMIC_RESOURCES_REVIEW": {
      "primary_metric": null,
      "target_value": null,
      "direction": "higher_better",
      "weight": 3,
      "unit": "qualitative score",
      "rationale": "Long-horizon; no near-term threshold applicable"
    },
    "DEEP_TIME_RISKS_REVIEW": {
      "primary_metric": null,
      "target_value": null,
      "direction": "lower_better",
      "weight": 5,

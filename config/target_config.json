      "reference_worst": 50.0,
      "direction": "lower_better",
      "weight": 9,
      "unit": "percent below $2.15/day",
      "rationale": "SDG1: end extreme poverty; reference_worst=50% (1990s global baseline)"
    },
    "INFRASTRUCTURE_CITIES_REVIEW": {
      "primary_metric": "urbanization_pct",
      "target_value": null,
      "direction": "stable_better",
      "weight": 5,
      "unit": "percent urban",
